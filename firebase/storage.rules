rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    match /users/{uid}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && request.resource.size < 5 * 1024 * 1024;
    }

    match /posts/{postId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.size < 10 * 1024 * 1024;
    }

    match /jobs/{jobId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['alumni', 'lecturer', 'admin']
      );
    }

    match /chat_media/{chatId}/{allPaths=**} {
      allow read: if isAuthenticated(); // Should ideally be checked against chat participants
      allow write: if isAuthenticated();
    }
  }
}
