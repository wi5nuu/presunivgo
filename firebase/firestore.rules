rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidDomain() {
      return request.auth.token.email.matches('.*@(student\\.)?president\\.ac\\.id');
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.author_uid == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.author_uid == request.auth.uid || isAdmin()
      );
    }
    
    // Comments subcollection on posts
    match /posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.author_uid == request.auth.uid || isAdmin()
      );
    }
    
    // Jobs collection
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isEmailVerified() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['alumni', 'lecturer', 'admin']
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.posted_by_uid == request.auth.uid || isAdmin()
      );
    }
    
    // Applications - private
    match /applications/{appId} {
      allow read: if isAuthenticated() && (
        resource.data.applicant_uid == request.auth.uid ||
        resource.data.job_owner_uid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isEmailVerified();
      allow update: if resource.data.job_owner_uid == request.auth.uid || isAdmin();
    }
    
    // Chats - participants only
    match /chats/{chatId} {
      // Allow listing/reading if authenticated (for empty-state display)
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
    }
    
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Student Clubs - all authenticated users can read
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid in resource.data.member_uids
      );
      allow delete: if isAdmin();
    }

    match /clubs/{clubId}/channels/{channelId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    match /clubs/{clubId}/channels/{channelId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.sender_uid == request.auth.uid || isAdmin()
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, delete: if isAuthenticated() &&
        resource.data.recipient_uid == request.auth.uid;
      allow create: if isAuthenticated();
    }
  }
}
